{
  "name": "solana-traderclaw",
  "version": "1.0.30",
  "description": "TraderClaw V1 — autonomous Solana memecoin trading for OpenClaw (team edition: X/Twitter journal and engagement tools)",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "traderclaw": "bin/traderclaw.cjs"
  },
  "files": [
    "dist/",
    "bin/*.mjs",
    "bin/*.cjs",
    "skills/",
    "config/",
    "lib/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "traderclaw",
    "openclaw",
    "solana",
    "memecoin",
    "trading",
    "agent",
    "plugin",
    "x",
    "twitter",
    "journal",
    "team"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "esbuild": "^0.24.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
