{
  "name": "traderclaw-team-v1-upgraded",
  "version": "1.1.0",
  "description": "TraderClaw Team V1-Upgraded — founders edition Solana trading agent with X/Twitter journal & engagement, standardized tool envelopes, intelligence lab, prompt scrubbing, and split skill architecture",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "traderclaw": "./bin/openclaw-trader.mjs"
  },
  "files": [
    "dist/",
    "bin/*.mjs",
    "skills/",
    "config/",
    "lib/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "traderclaw",
    "openclaw",
    "solana",
    "memecoin",
    "trading",
    "agent",
    "plugin",
    "x",
    "twitter",
    "journal",
    "team",
    "intelligence",
    "upgraded"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "esbuild": "^0.24.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
